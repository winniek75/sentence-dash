// composables/useMokun.ts\
import \{ ref, computed \} from 'vue'\
import \{ supabase \} from '@/lib/supabase'\
\
export function useMokun(userId: string) \{\
  const mokunState = ref<MokunState>(\{\
    growth_stage: 0,\
    happiness: 50,\
    last_interaction: new Date(),\
    user_streak: 0,\
    total_progress: 0\
  \})\
  \
  // \uc0\u24184 \u31119 \u24230 \u35336 \u31639 \
  const happinessLevel = computed(() => \{\
    if (mokunState.value.happiness >= 80) return 'very_happy'\
    if (mokunState.value.happiness >= 60) return 'happy'\
    if (mokunState.value.happiness >= 40) return 'neutral'\
    if (mokunState.value.happiness >= 20) return 'sad'\
    return 'very_sad'\
  \})\
  \
  // \uc0\u12452 \u12505 \u12531 \u12488 \u21029 \u21453 \u24540 \
  function getMokunReaction(event: string): \{\
    animation: string;\
    message: string;\
    sound?: string;\
  \} \{\
    const reactions = \{\
      correct_answer: [\
        \{ animation: 'jump_joy', message: '\uc0\u12420 \u12387 \u12383 \u65281 ', sound: 'cheer.mp3' \},\
        \{ animation: 'clap', message: '\uc0\u12377 \u12372 \u12356 \u65281 ', sound: 'applause.mp3' \},\
        \{ animation: 'spin', message: '\uc0\u23436 \u29863 \u12384 \u12424 \u65281 ', sound: 'success.mp3' \}\
      ],\
      wrong_answer: [\
        \{ animation: 'think_hard', message: '\uc0\u22823 \u19976 \u22827 \u12289 \u12418 \u12358 \u19968 \u24230 \u65281 ', sound: 'hmm.mp3' \},\
        \{ animation: 'scratch_head', message: '\uc0\u12498 \u12531 \u12488 \u35211 \u12427 \u65311 ', sound: null \},\
        \{ animation: 'encourage', message: '\uc0\u24796 \u12375 \u12356 \u65281 \u12354 \u12392 \u23569 \u12375 \u65281 ', sound: 'encourage.mp3' \}\
      ],\
      streak_broken: \{\
        animation: 'sad_wilt',\
        message: '\uc0\u20037 \u12375 \u12406 \u12426 \'85\u24453 \u12387 \u12390 \u12383 \u12424 \u55357 \u56866 ',\
        sound: 'sad.mp3'\
      \},\
      new_level: \{\
        animation: 'bloom_flower',\
        message: '\uc0\u26032 \u12375 \u12356 \u12524 \u12505 \u12523 \u12384 \u65281 \u19968 \u32210 \u12395 \u38929 \u24373 \u12429 \u12358 \u65281 \u55356 \u57144 ',\
        sound: 'levelup.mp3'\
      \},\
      daily_first_login: \{\
        animation: 'wave_hello',\
        message: '\uc0\u12362 \u12399 \u12424 \u12358 \u65281 \u20170 \u26085 \u12418 \u38929 \u24373 \u12429 \u12358 \u12397 \u65281 ',\
        sound: 'morning.mp3'\
      \},\
      study_5min: \{\
        animation: 'thumbs_up',\
        message: '5\uc0\u20998 \u36948 \u25104 \u65281 \u12356 \u12356 \u35519 \u23376 \u12384 \u12424 \u65281 ',\
        sound: 'good.mp3'\
      \},\
      study_30min: \{\
        animation: 'celebrate',\
        message: '30\uc0\u20998 \u12418 \u38929 \u24373 \u12387 \u12383 \u12397 \u65281 \u12377 \u12372 \u12356 \u65281 ',\
        sound: 'amazing.mp3'\
      \}\
    \}\
    \
    if (event === 'correct_answer' || event === 'wrong_answer') \{\
      const options = reactions[event]\
      return options[Math.floor(Math.random() * options.length)]\
    \}\
    \
    return reactions[event as keyof typeof reactions] || \{\
      animation: 'idle',\
      message: '\uc0\u38929 \u24373 \u12387 \u12390 \u65281 ',\
      sound: null\
    \}\
  \}\
  \
  // Mo\uc0\u12367 \u12435 \u25104 \u38263 \u12481 \u12455 \u12483 \u12463 \
  async function checkGrowth(currentXP: number) \{\
    const newStage = Object.entries(GROWTH_THRESHOLDS)\
      .reverse()\
      .find(([_, threshold]) => currentXP >= threshold.xp)?.[0]\
    \
    const stageNumber = parseInt(newStage || '0')\
    \
    if (stageNumber > mokunState.value.growth_stage) \{\
      mokunState.value.growth_stage = stageNumber as MokunState['growth_stage']\
      \
      // \uc0\u25104 \u38263 \u28436 \u20986 \
      await showGrowthAnimation(stageNumber)\
      \
      // DB\uc0\u26356 \u26032 \
      await supabase\
        .from('user_profiles')\
        .update(\{ mokun_growth_stage: stageNumber \})\
        .eq('id', userId)\
      \
      // \uc0\u12452 \u12531 \u12479 \u12521 \u12463 \u12471 \u12519 \u12531 \u35352 \u37682 \
      await supabase\
        .from('mokun_interactions')\
        .insert(\{\
          user_id: userId,\
          event_type: 'growth',\
          mokun_reaction: 'bloom_flower',\
          message: `Mo\uc0\u12367 \u12435 \u12364 \u12300 $\{GROWTH_THRESHOLDS[stageNumber].name\}\u12301 \u12395 \u25104 \u38263 \u12375 \u12383 \u12424 \u65281 `\
        \})\
    \}\
  \}\
  \
  // \uc0\u24184 \u31119 \u24230 \u26356 \u26032 \
  async function updateHappiness(delta: number) \{\
    mokunState.value.happiness = Math.max(0, Math.min(100, mokunState.value.happiness + delta))\
    \
    await supabase\
      .from('user_profiles')\
      .update(\{ mokun_happiness: mokunState.value.happiness \})\
      .eq('id', userId)\
  \}\
  \
  return \{\
    mokunState,\
    happinessLevel,\
    getMokunReaction,\
    checkGrowth,\
    updateHappiness\
  \}\
\}\
